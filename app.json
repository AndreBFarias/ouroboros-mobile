{
  "expo": {
    "name": "ouroboros-mobile",
    "slug": "ouroboros-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "ouroboros",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#282a36"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ouroboros.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#282a36"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "SEND",
          "category": ["DEFAULT"],
          "data": [
            { "mimeType": "image/*" },
            { "mimeType": "application/pdf" }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Ouroboros precisa acessar suas fotos para configurar seu avatar de perfil.",
          "cameraPermission": "O Ouroboros precisa da câmera para tirar uma foto de perfil."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir detectar bairro para anotar onde foi."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#bd93f9",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir biometria para desbloquear o Ouroboros."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "repoUrl": "https://github.com/AndreBFarias/Protocolo-Mob-Ouroboros",
      "license": "GPL-3.0"
    }
  }
}
