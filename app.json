{
  "expo": {
    "name": "Ouroboros",
    "slug": "ouroboros-mobile",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": [
      "ouroboros",
      "com.googleusercontent.apps.691237256846-tl2edd8uvb6bbn6men478c0agq7ea91p"
    ],
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#14151a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ouroboros.mobile",
      "label": "Ouroboros",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#14151a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.WRITE_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.WRITE_BODY_FAT",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_MENSTRUATION",
        "android.permission.health.WRITE_MENSTRUATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Ouroboros precisa acessar suas fotos para configurar seu avatar de perfil.",
          "cameraPermission": "O Ouroboros precisa da câmera para tirar uma foto de perfil."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir detectar bairro para anotar onde foi."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-foreground.png",
          "color": "#bd93f9",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/alarmes/gentle.wav",
            "./assets/sounds/alarmes/normal.wav",
            "./assets/sounds/alarmes/forte.wav",
            "./assets/sounds/alarmes/chime.wav",
            "./assets/sounds/alarmes/marimba.wav"
          ]
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir biometria para desbloquear o Ouroboros."
        }
      ],
      "./modules/widget-homescreen/app.plugin.js",
      [
        "expo-av",
        {
          "microphonePermission": "Permitir gravar áudio para transcrever na hora."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permitir gravar áudio para transcrever na hora.",
          "speechRecognitionPermission": "Permitir reconhecimento de voz para preencher o diário."
        }
      ],
      "expo-web-browser",
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "text/*",
            "image/*",
            "application/pdf",
            "application/octet-stream"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "repoUrl": "https://github.com/AndreBFarias/Protocolo-Mob-Ouroboros",
      "license": "GPL-3.0",
      "router": {},
      "eas": {
        "projectId": "27c5d3d3-1110-49c1-8457-a99c6249f320"
      }
    },
    "owner": "andre_farias"
  }
}
