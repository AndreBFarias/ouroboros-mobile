#!/usr/bin/env bash
# Pre-commit hook: bloqueia commit se anonimato ou dados de teste estiverem
# violados. Roda lint nos arquivos staged quando o projeto existir.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

./scripts/check_anonimato.sh
./scripts/check_test_data.sh

# M-PT-BR-AUDIT (2026-05-04): bloqueia commit com strings UI sem
# acentuacao canonica em src/ ou app/. Override por linha via
# // ptbr-allow: <razao> ou exclusao em batch via .ptbr-violations.txt
python3 scripts/check_strings_ui_ptbr.py

if [[ -f package.json ]]; then
  STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
  if [[ -n "$STAGED" ]]; then
    # AUDIT-T3-DX D1 (2026-05-15): auto-formato silencioso via prettier
    # nos arquivos staged antes do lint. Filosofia identica ao bloco
    # anonimato/whitespace existente: nao bloqueia, apenas formata e
    # re-stagea. Se prettier falhar (binario ausente), ignora silencioso
    # para nao quebrar commit em maquina sem node_modules.
    npx --no-install prettier --write --log-level=warn $STAGED 2>/dev/null || true
    git add $STAGED
    npx --no-install eslint $STAGED || { echo "ERRO: eslint falhou nos arquivos staged"; exit 1; }
  fi
fi
