# Diretorio temporario do playwright MCP (screenshots vao para
# docs/sprints/*-screenshots/ apos curadoria)
.playwright-mcp/

# APKs locais baixados de EAS dev-client / preview / production builds.
# Cada build sai com timestamp; baixar de novo via expo.dev se precisar.
builds/

# Keystore Android para release v1.0.0+. Backup manual em local seguro
# (USB criptografado fora do git). Caso a chave seja perdida, novas
# releases precisam de novo identificador no Play Store -- por isso
# o backup deve sobreviver ao computador.
credentials/keystore.jks
credentials/keystore.json

# Arquivos de instrucao/orquestracao para IA (CLAUDE.md, HANDOFF, etc).
# Mantidos apenas localmente -- nao versionar (Regra -1, anonimato).
CLAUDE.md
HANDOFF-PROMPT.md
HOW_TO_RESUME.md
VALIDATOR_BRIEF.md
STATE.md
