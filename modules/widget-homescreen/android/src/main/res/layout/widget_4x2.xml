<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/dracula_bg"
  android:padding="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/widget_avatar_inicial"
      android:layout_width="44dp"
      android:layout_height="44dp"
      android:gravity="center"
      android:textColor="@color/dracula_bg"
      android:textSize="20sp"
      android:textStyle="bold"
      android:fontFamily="monospace"
      android:background="@color/dracula_purple"
      android:text="A" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="12dp"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widget_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/dracula_muted"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:text="@string/widget_titulo_humor" />

      <TextView
        android:id="@+id/widget_humor_valor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/dracula_fg"
        android:fontFamily="monospace"
        android:textSize="22sp"
        android:textStyle="bold"
        android:text="—" />
    </LinearLayout>
  </LinearLayout>

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:background="@color/dracula_bg_elev" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="4">

    <TextView
      android:id="@+id/widget_btn_humor"
      android:layout_width="0dp"
      android:layout_height="44dp"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:gravity="center"
      android:textColor="@color/dracula_fg"
      android:fontFamily="monospace"
      android:textSize="11sp"
      android:background="@color/dracula_bg_elev"
      android:text="@string/widget_atalho_humor" />

    <TextView
      android:id="@+id/widget_btn_voz"
      android:layout_width="0dp"
      android:layout_height="44dp"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:gravity="center"
      android:textColor="@color/dracula_fg"
      android:fontFamily="monospace"
      android:textSize="11sp"
      android:background="@color/dracula_bg_elev"
      android:text="@string/widget_atalho_voz" />

    <TextView
      android:id="@+id/widget_btn_camera"
      android:layout_width="0dp"
      android:layout_height="44dp"
      android:layout_weight="1"
      android:layout_marginEnd="6dp"
      android:gravity="center"
      android:textColor="@color/dracula_fg"
      android:fontFamily="monospace"
      android:textSize="11sp"
      android:background="@color/dracula_bg_elev"
      android:text="@string/widget_atalho_camera" />

    <TextView
      android:id="@+id/widget_btn_vitoria"
      android:layout_width="0dp"
      android:layout_height="44dp"
      android:layout_weight="1"
      android:gravity="center"
      android:textColor="@color/dracula_fg"
      android:fontFamily="monospace"
      android:textSize="11sp"
      android:background="@color/dracula_bg_elev"
      android:text="@string/widget_atalho_vitoria" />
  </LinearLayout>
</LinearLayout>
