<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:gravity="center"
  android:background="@color/dracula_bg"
  android:padding="16dp">

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textColor="@color/dracula_muted"
    android:fontFamily="monospace"
    android:textSize="13sp"
    android:textStyle="bold"
    android:text="@string/widget_desativado_titulo" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:textColor="@color/dracula_muted_decor"
    android:fontFamily="monospace"
    android:textSize="11sp"
    android:textAlignment="center"
    android:lineSpacingMultiplier="1.4"
    android:text="@string/widget_desativado_sub" />
</LinearLayout>
